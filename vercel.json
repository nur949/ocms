{
  "version": 2,
  "installCommand": "pnpm install && pnpm --filter @ocms/api build && pnpm --filter @ocms/web build",
  "builds": [
    {
      "src": "apps/api/dist/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "apps/web/dist/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/apps/api/dist/index.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/apps/web/dist/assets/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/apps/web/dist/index.html"
    }
  ]
}
